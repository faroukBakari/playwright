{
  "name": "playwright-core",
  "version": "1.59.0-next",
  "description": "A high-level API to automate web browsers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/microsoft/playwright.git"
  },
  "homepage": "https://playwright.dev",
  "engines": {
    "node": ">=18"
  },
  "author": {
    "name": "Microsoft Corporation"
  },
  "license": "Apache-2.0",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.js",
      "default": "./index.js"
    },
    "./package.json": "./package.json",
    "./src/outofprocess": "./src/outofprocess.ts",
    "./src/mcpBundle": "./src/mcpBundle.ts",
    "./src/mcp/config": "./src/mcp/config.ts",
    "./src/mcp/exports": "./src/mcp/exports.ts",
    "./src/tools/exports": "./src/tools/exports.ts",
    "./src/tools/perfLog": "./src/tools/perfLog.ts",
    "./src/mcp/index": "./src/mcp/index.ts",
    "./src/mcp/program": "./src/mcp/program.ts",
    "./src/remote/playwrightServer": "./src/remote/playwrightServer.ts",
    "./src/server": "./src/server/index.ts",
    "./src/server/utils/image_tools/stats": "./src/server/utils/image_tools/stats.ts",
    "./src/server/utils/image_tools/compare": "./src/server/utils/image_tools/compare.ts",
    "./src/server/utils/image_tools/imageChannel": "./src/server/utils/image_tools/imageChannel.ts",
    "./src/server/utils/image_tools/colorUtils": "./src/server/utils/image_tools/colorUtils.ts",
    "./src/server/registry/index": "./src/server/registry/index.ts",
    "./src/utils": "./src/utils.ts",
    "./src/utilsBundle": "./src/utilsBundle.ts",
    "./src/zipBundle": "./src/zipBundle.ts"
  },
  "bin": {
    "playwright-core": "cli.js"
  },
  "types": "types/types.d.ts"
}
